# --- Twitch ---
# Helix API app credentials (https://dev.twitch.tv/console/apps). Used to resolve VOD metadata.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- LLM (Anthropic Claude) ---
ANTHROPIC_API_KEY=

# --- Upload OAuth (optional; connect each platform in the Settings UI) ---
# Public base URL of this app = OAuth redirect target. Register
#   <PUBLIC_URL>/oauth/<platform>/callback  in each developer app.
PUBLIC_URL=https://suite.raumdock.org/vod
# YouTube/Google OAuth client (type: Web application)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# TikTok Login Kit app
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Facebook app (Instagram Graph API)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Web interface ---
# Per-user logins for the web UI: comma-separated user:password pairs.
USERS=admin:change-me
# Signs the session cookie. Set a long random value; keep stable to avoid forced re-login.
#   openssl rand -hex 32
SESSION_SECRET=
# App listen port inside the container.
WEB_PORT=9443
# URL prefix when served behind the suite reverse proxy. Empty for standalone.
#   prod (suite.raumdock.org/vod): /vod
ROOT_PATH=
