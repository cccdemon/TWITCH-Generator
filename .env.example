# --- Twitch ---
# Helix API app credentials (https://dev.twitch.tv/console/apps). Used to resolve VOD metadata.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- LLM (Anthropic Claude) ---
ANTHROPIC_API_KEY=

# --- YouTube upload (optional) ---
# OAuth client secrets JSON path (Desktop app credential) mounted into the container.
YOUTUBE_CLIENT_SECRETS=/data/secrets/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=/data/secrets/youtube_token.json

# --- TikTok / Instagram (optional, see README) ---
TIKTOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- Web interface ---
# Per-user logins for the web UI: comma-separated user:password pairs.
USERS=admin:change-me
# Signs the session cookie. Set a long random value; keep stable to avoid forced re-login.
#   openssl rand -hex 32
SESSION_SECRET=
# App listen port inside the container.
WEB_PORT=9443
# URL prefix when served behind the suite reverse proxy. Empty for standalone.
#   prod (suite.raumdock.org/vod): /vod
ROOT_PATH=
